{
  "permissions": {
    "allow": [
      "Bash(cd)",
      "Bash(grep)",
      "Bash(sed)",
      "Bash(ls)",
      "Bash(find)",
      "Bash(./gradlew)",
      "Bash(git add)",
      "Bash(git cherry-pick)",
      "Bash(git log)",
      "Bash(git status)",
      "Bash(git stash)",
      "Bash(git branch)",
      "Bash(git checkout)",
      "Bash(git diff)",
      "Bash(git switch)"
    ],
    "ask": [
      "Bash(git push:*)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"💣 Claude Code need your answer\" with title \"Claude Code\"'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"✨Done Claude Code\" with title \"Claude Code\"'"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "pgrep -P $PPID -f 'kotlin-lsp' | xargs -r kill 2>/dev/null; sleep 1; pgrep -P $PPID -f 'kotlin-lsp' | xargs -r kill -9 2>/dev/null; true"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "kotlin-lsp@claude-plugins-official": true
  },
  "skipDangerousModePermissionPrompt": true
}
